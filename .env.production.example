# Next.js runtime (production)
# Required
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
# Injector target configuration
INJECTOR_APP_BASE_URL=http://127.0.0.1:3001
INJECTOR_TARGET_NAME=local-development
# Security/session hardening (recommended)
ACTOR_SESSION_SECRET=replace-with-a-strong-random-secret
POS_ENABLE_ASSUME_USER_BRIDGE=false
APP_ENV=production

# Optional runtime tuning
# POS_DEFAULT_APP_USER_ID=user_admin_bootstrap
# PRODUCT_SOURCING_PROVIDER_MIN_INTERVAL_MS=350

# Migration tooling (CLI only, not used by Next.js runtime)
# Keep this in a private env file (for example .env.production.local), never commit secrets.
# SUPABASE_DB_URL=postgresql://user:password@host:5432/postgres?sslmode=require
# Optional sslmode override (replaces URL sslmode if already present):
# SUPABASE_DB_SSLMODE=require
# Railway proxy endpoints may require:
# SUPABASE_DB_SSLMODE=disable
# Optional psql sync script env override:
# DATABASE_URL=postgresql://user:password@host:5432/postgres
