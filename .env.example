# Supabase local/dev configuration
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key

# Injector target configuration
INJECTOR_APP_BASE_URL=http://127.0.0.1:3001
INJECTOR_TARGET_NAME=local-development
# Keep false by default. Set true only for intentional remote mutations.
INJECTOR_ALLOW_REMOTE_WRITE=false
# Keep false by default. Demo auth users should not be provisioned on remote targets.
INJECTOR_ALLOW_DEMO_AUTH_USERS_ON_REMOTE=false

# Optional explicit injector overrides (when different from app env)
# INJECTOR_SUPABASE_URL=https://your-project.supabase.co
# INJECTOR_SUPABASE_ANON_KEY=replace-with-anon-key
# INJECTOR_SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Optional onboarding admin bootstrap
INJECTOR_ONBOARDING_ADMIN_APP_USER_ID=user_admin_bootstrap
INJECTOR_ONBOARDING_ADMIN_NAME=System Admin
INJECTOR_ONBOARDING_ADMIN_EMAIL=admin@simple-pos.local
INJECTOR_ONBOARDING_ADMIN_PASSWORD_LENGTH=20
INJECTOR_ONBOARDING_ADMIN_RESET_PASSWORD=true
INJECTOR_ONBOARDING_ADMIN_FORCE_EMAIL_CONFIRM=true
