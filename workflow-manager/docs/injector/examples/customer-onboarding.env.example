# Injector connection (required by injector.sh)
NEXT_PUBLIC_SUPABASE_URL=https://your-kong-or-supabase-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Required onboarding inputs
ONBOARD_TENANT_NAME=Acme Store
ONBOARD_OWNER_EMAIL=owner@acme.test
ONBOARD_OWNER_PASSWORD=ChangeMe123!

# Optional onboarding customizations
ONBOARD_OWNER_NAME=Acme Owner
ONBOARD_OWNER_ROLE=OWNER
ONBOARD_CLAIM_ASSETS_BUCKET=claim-assets
ONBOARD_TENANT_DEK=
ONBOARD_TENANT_ID=
ONBOARD_TENANT_KEY=
ONBOARD_USER_KEY=
ONBOARD_TEMPLATE_KEY=
ONBOARD_TEMPLATE_NAME=
ONBOARD_TEMPLATE_LAYOUT_VARIANT=order-cards
ONBOARD_TEMPLATE_STATUS=DRAFT
ONBOARD_TEMPLATE_PUBLISH=true
ONBOARD_TEMPLATE_IS_DEFAULT=true
ONBOARD_TEMPLATE_SKUS=

# Optional API client creation
ONBOARD_CREATE_API_CLIENT=true
ONBOARD_API_CLIENT_REF=
ONBOARD_API_CLIENT_NAME=
ONBOARD_API_KEY=
