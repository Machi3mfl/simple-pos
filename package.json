{
  "name": "simple-pos",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev --port 3001",
    "dev:local": "bash scripts/supabase/dev-local.sh",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "next lint",
    "supabase:start": "bash scripts/supabase/start-local.sh",
    "supabase:stop": "bash scripts/supabase/stop-local.sh",
    "supabase:reset": "bash scripts/supabase/reset-local.sh",
    "supabase:status": "bash scripts/supabase/status-local.sh",
    "supabase:env": "bash scripts/supabase/write-local-env.sh",
    "supabase:migrate:remote": "bash scripts/supabase/sync-remote-migrations.sh",
    "supabase:migrate:remote:dry-run": "bash scripts/supabase/sync-remote-migrations.sh --dry-run",
    "supabase:migrate:remote:cli": "bash scripts/supabase/push-remote.sh",
    "supabase:migrate:remote:cli:dry-run": "bash scripts/supabase/push-remote.sh --dry-run",
    "probe:product-sourcing:carrefour": "bash tests/scripts/run-product-sourcing-provider-smoke.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:release-gate:real": "bash tests/scripts/run-e2e-release-gate-real.sh",
    "test:e2e:ui:real:modules": "bash tests/scripts/run-e2e-ui-real-modules.sh",
    "tutorials:record": "bash tests/scripts/run-tutorial-recordings.sh",
    "tutorials:record:cash": "bash tests/scripts/run-tutorial-recordings.sh tests/tutorials/cash-register-open-close.tutorial.spec.ts",
    "tutorials:record:checkout": "bash tests/scripts/run-tutorial-recordings.sh tests/tutorials/checkout-cash-and-on-account.tutorial.spec.ts",
    "tutorials:record:products": "bash tests/scripts/run-tutorial-recordings.sh tests/tutorials/products-search-edit-stock.tutorial.spec.ts",
    "tutorials:export": "bash tests/scripts/export-tutorial-videos.sh",
    "tutorials:smoke:cash": "TUTORIAL_OUTPUT_DIR=./test-results/tutorials-smoke TUTORIAL_SLOW_MO_MS=0 TUTORIAL_STEP_DELAY_MS=0 TUTORIAL_TYPING_DELAY_MS=0 TUTORIAL_SUCCESS_HOLD_MS=0 TUTORIAL_NAVIGATION_HOLD_MS=0 TUTORIAL_INTRO_HOLD_MS=0 bash tests/scripts/run-tutorial-recordings.sh tests/tutorials/cash-register-open-close.tutorial.spec.ts",
    "tutorials:smoke:checkout": "TUTORIAL_OUTPUT_DIR=./test-results/tutorials-smoke TUTORIAL_SLOW_MO_MS=0 TUTORIAL_STEP_DELAY_MS=0 TUTORIAL_TYPING_DELAY_MS=0 TUTORIAL_SUCCESS_HOLD_MS=0 TUTORIAL_NAVIGATION_HOLD_MS=0 TUTORIAL_INTRO_HOLD_MS=0 bash tests/scripts/run-tutorial-recordings.sh tests/tutorials/checkout-cash-and-on-account.tutorial.spec.ts",
    "tutorials:smoke:products": "TUTORIAL_OUTPUT_DIR=./test-results/tutorials-smoke TUTORIAL_SLOW_MO_MS=0 TUTORIAL_STEP_DELAY_MS=0 TUTORIAL_TYPING_DELAY_MS=0 TUTORIAL_SUCCESS_HOLD_MS=0 TUTORIAL_NAVIGATION_HOLD_MS=0 TUTORIAL_INTRO_HOLD_MS=0 bash tests/scripts/run-tutorial-recordings.sh tests/tutorials/products-search-edit-stock.tutorial.spec.ts"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.562.0",
    "next": "^14.2.35",
    "react": "^18",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
